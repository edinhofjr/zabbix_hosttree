{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "types": ["jquery"],
    "rootDir": "partials/ts",
    "outDir": "partials/js",
    "sourceMap": false,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["partials/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
